{
  "name": "bwebsouk",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production && node scripts/copy-public.js",
    "scrape:ae": "node scripts/scraper-aliexpress.js --pages 5",
    "scrape:px": "node scripts/scraper-pixmania.js --pages 5",
    "build-products": "node scripts/build-products.js",
    "build-products:dry": "node scripts/build-products.js --dry-run",
    "pipeline": "npm run scrape:ae && npm run scrape:px && npm run build-products"
  },
  "dependencies": {
    "puppeteer": "^24.7.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.15",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}